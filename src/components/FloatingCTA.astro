---
import { SITE } from '@/data/site';
import Icon from './Icon.astro';
---
<div id="floating-cta" class="fixed bottom-4 right-4 z-40 lg:hidden opacity-0 pointer-events-none transition-all duration-300 translate-y-3">
  <div class="flex items-center gap-2 bg-snow/95 backdrop-blur border border-line shadow-lift rounded-pill p-1.5">
    <a href={`tel:${SITE.phoneTel}`} class="inline-flex items-center gap-2 bg-brand-red text-white rounded-pill px-4 py-2.5 text-[13px] font-display font-semibold uppercase tracking-wider">
      <Icon name="phone" size={14} /> Call
    </a>
    <a href="/colour-matching" class="inline-flex items-center gap-2 text-ink rounded-pill px-3.5 py-2 text-[13px] font-display font-semibold uppercase tracking-wider">
      <Icon name="palette" size={14} /> Match
    </a>
  </div>
</div>

<script>
  const el = document.getElementById('floating-cta');
  function onScroll() {
    if (!el) return;
    if (window.scrollY > 520) {
      el.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-3');
      el.classList.add('opacity-100', 'translate-y-0');
    } else {
      el.classList.add('opacity-0', 'pointer-events-none', 'translate-y-3');
      el.classList.remove('opacity-100', 'translate-y-0');
    }
  }
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
