---
import Icon from './Icon.astro';
import type { Category } from '@/data/categories';
interface Props { category: Category; index?: number; }
const { category: c, index = 0 } = Astro.props;
const accent = index % 2 === 0 ? 'red' : 'blue';
---
<a
  href={`/shop/${c.slug}`}
  class={`card-lift group block relative overflow-hidden rounded-3xl border border-line bg-snow reveal`}
  data-delay={`${(index % 4) + 1}`}
>
  <div class="relative aspect-[4/3] overflow-hidden bg-bone">
    <img
      src={c.image}
      alt={c.title}
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-[900ms] ease-[cubic-bezier(.2,.7,.2,1)] group-hover:scale-[1.06]"
    />
    <div class={`absolute inset-0 bg-gradient-to-t ${accent === 'red' ? 'from-brand-red/55' : 'from-brand-blue/55'} via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500`}></div>
    <div class={`absolute top-4 left-4 w-11 h-11 rounded-2xl backdrop-blur-md grid place-items-center ${accent === 'red' ? 'bg-brand-red/90 text-white' : 'bg-brand-blue/90 text-white'} shadow-lift`}>
      <Icon name={c.icon as any} size={20} />
    </div>
    <span class="absolute top-4 right-4 font-mono text-[11px] tracking-tight bg-white/90 backdrop-blur text-ink px-2.5 py-1 rounded-full">{c.count}</span>
  </div>
  <div class="p-6">
    <h3 class="h-card text-ink group-hover:text-brand-red transition-colors">{c.title}</h3>
    <p class="mt-2.5 text-[14.5px] text-muted leading-relaxed text-pretty">{c.blurb}</p>
    <div class={`mt-5 inline-flex items-center gap-2 font-display uppercase tracking-wider text-[12px] ${accent === 'red' ? 'text-brand-red' : 'text-brand-blue'}`}>
      Browse Range
      <span class="arrow inline-flex"><Icon name="arrow-right" size={14} /></span>
    </div>
  </div>
</a>
