---
import { SITE } from '@/data/site';
import Icon from './Icon.astro';
interface Props {
  title?: string;
  body?: string;
}
const {
  title = 'Need a colour mixed today?',
  body  = 'Walk into the shop, give us a ring or send us the paint code. We will have it on the bench within the hour.',
} = Astro.props;
---
<section class="relative overflow-hidden mesh-blue-dark py-20 lg:py-28">
  <div class="noise absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <div class="container-x relative">
    <div class="max-w-3xl">
      <p class="eyebrow text-brand-red-soft reveal" style="--tw-text-opacity:1;">Quick Action</p>
      <h2 class="h-section mt-4 text-white text-balance reveal" data-delay="1">{title}</h2>
      <p class="mt-5 text-white/70 text-lg text-pretty leading-relaxed reveal" data-delay="2">{body}</p>
      <div class="flex flex-wrap gap-3 mt-8 reveal" data-delay="3">
        <a href={`tel:${SITE.phoneTel}`} class="btn-primary"><Icon name="phone" size={16} /><span>{SITE.phone}</span><Icon name="arrow-right" class="arrow" size={15} /></a>
        <a href="/colour-matching" class="btn-secondary !text-white !bg-white/10 !border-white/15 hover:!bg-white/15"><Icon name="palette" size={16} /><span>Colour Match Tool</span></a>
      </div>
    </div>
  </div>
</section>
