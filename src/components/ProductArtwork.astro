---
// On-brand artwork for product cards — replaces all Unsplash imagery.
// Each artwork is a stylised representation of the actual product format:
// tin / aerosol / paper roll / kit — drawn inline as SVG over a brand
// gradient. Always relevant, always crisp, never the wrong stock image.

interface Props {
  slug: string;
  brand: string;
  category: string;
  price?: string;
}
const { slug, brand, category, price } = Astro.props;

const STYLES: Record<string, { bg: string; ink: 'white' | 'ink'; accent: string; kind: 'tin' | 'aerosol' | 'roll' | 'kit' | 'light' }> = {
  'roar-610-extreme-cut-plus-1kg':         { bg: 'linear-gradient(135deg, #CE2A2D 0%, #A8181B 100%)', ink: 'white', accent: '#FFE3E3', kind: 'tin' },
  '5w-smd-led-rechargeable-spray-gun-light': { bg: 'linear-gradient(135deg, #1C3A6F 0%, #0C2146 100%)', ink: 'white', accent: '#FFFAD5', kind: 'light' },
  'masking-paper-jumbo':                   { bg: 'linear-gradient(135deg, #F0E9D6 0%, #C9A572 100%)', ink: 'ink',   accent: '#7A5A2B', kind: 'roll' },
  'novol-spectral-klar-565-vhs-clear-kit': { bg: 'linear-gradient(135deg, #DCE4F0 0%, #6E8AB8 100%)', ink: 'ink',   accent: '#0C2146', kind: 'kit' },
};
const s = STYLES[slug] ?? STYLES['roar-610-extreme-cut-plus-1kg'];
const ink = s.ink === 'white' ? '#FFFFFF' : '#0F172A';
const subtle = s.ink === 'white' ? 'rgb(255 255 255 / 0.65)' : 'rgb(15 23 42 / 0.58)';
const sheen  = s.ink === 'white' ? 'rgb(255 255 255 / 0.10)' : 'rgb(15 23 42 / 0.06)';
---
<div class="product-artwork relative w-full aspect-square overflow-hidden" style={`background: ${s.bg};`}>
  <!-- Subtle workshop-grade noise/dots overlay -->
  <svg viewBox="0 0 300 300" preserveAspectRatio="xMidYMid slice" class="absolute inset-0 w-full h-full" aria-hidden="true">
    <defs>
      <pattern id={`dots-${slug}`} width="12" height="12" patternUnits="userSpaceOnUse">
        <circle cx="0.8" cy="0.8" r="0.7" fill={sheen} opacity="0.85"/>
      </pattern>
      <radialGradient id={`spot-${slug}`} cx="20%" cy="15%" r="70%">
        <stop offset="0%" stop-color={sheen} stop-opacity="1"/>
        <stop offset="100%" stop-color={sheen} stop-opacity="0"/>
      </radialGradient>
    </defs>
    <rect width="300" height="300" fill={`url(#dots-${slug})`} opacity="0.6"/>
    <rect width="300" height="300" fill={`url(#spot-${slug})`}/>
  </svg>

  <!-- Product silhouette centre -->
  <svg viewBox="0 0 300 300" class="absolute inset-0 w-full h-full" aria-hidden="true">
    {s.kind === 'tin' && (
      <g transform="translate(150 165)">
        <!-- Lid -->
        <ellipse cx="0" cy="-60" rx="62" ry="10" fill="rgba(0,0,0,0.18)"/>
        <rect x="-62" y="-65" width="124" height="10" rx="2" fill={s.accent}/>
        <!-- Body -->
        <rect x="-62" y="-55" width="124" height="110" rx="3" fill="rgba(0,0,0,0.18)"/>
        <rect x="-58" y="-52" width="116" height="104" rx="3" fill="white" opacity="0.92"/>
        <!-- Label band -->
        <rect x="-58" y="-22" width="116" height="40" fill="#CE2A2D"/>
        <text x="0" y="5" text-anchor="middle" font-family="Oswald, sans-serif" font-weight="700" font-size="20" fill="white" letter-spacing="1.5">{brand}</text>
        <text x="0" y="38" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="rgba(15,23,42,0.7)" letter-spacing="1">1 KG · POLISH</text>
        <!-- Handle -->
        <path d="M -40,-65 Q 0,-95 40,-65" stroke="rgba(0,0,0,0.25)" stroke-width="3" fill="none"/>
      </g>
    )}
    {s.kind === 'aerosol' && (
      <g transform="translate(150 165)">
        <ellipse cx="0" cy="80" rx="44" ry="6" fill="rgba(0,0,0,0.18)"/>
        <rect x="-42" y="-50" width="84" height="130" rx="6" fill="white" opacity="0.92"/>
        <rect x="-42" y="-15" width="84" height="44" fill="#CE2A2D"/>
        <text x="0" y="12" text-anchor="middle" font-family="Oswald, sans-serif" font-weight="700" font-size="14" fill="white" letter-spacing="1">{brand}</text>
        <!-- Cap -->
        <rect x="-26" y="-78" width="52" height="32" rx="4" fill={s.accent}/>
        <!-- Nozzle -->
        <rect x="-6" y="-86" width="12" height="10" fill="rgba(0,0,0,0.4)"/>
      </g>
    )}
    {s.kind === 'roll' && (
      <g transform="translate(150 165)">
        <!-- Side disc -->
        <ellipse cx="0" cy="0" rx="90" ry="20" fill="rgba(0,0,0,0.18)"/>
        <ellipse cx="0" cy="-6" rx="90" ry="20" fill="white" opacity="0.92"/>
        <ellipse cx="0" cy="-6" rx="22" ry="8" fill={s.accent} opacity="0.7"/>
        <circle cx="0" cy="-6" r="5" fill={s.accent}/>
        <!-- Edge highlight -->
        <ellipse cx="0" cy="-6" rx="90" ry="3" fill="rgba(255,255,255,0.4)"/>
      </g>
    )}
    {s.kind === 'kit' && (
      <g transform="translate(150 165)">
        <!-- Big tin -->
        <rect x="-72" y="-55" width="80" height="100" rx="3" fill="white" opacity="0.95"/>
        <rect x="-72" y="-15" width="80" height="36" fill="#1C3A6F"/>
        <text x="-32" y="9" text-anchor="middle" font-family="Oswald, sans-serif" font-weight="700" font-size="12" fill="white">NOVOL</text>
        <text x="-32" y="34" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="rgba(15,23,42,0.7)">5L · VHS</text>
        <!-- Small hardener tin -->
        <rect x="20" y="-25" width="40" height="70" rx="3" fill="white" opacity="0.95"/>
        <rect x="20" y="0" width="40" height="20" fill="#CE2A2D"/>
        <text x="40" y="13" text-anchor="middle" font-family="Oswald, sans-serif" font-weight="700" font-size="7" fill="white">HARDENER</text>
      </g>
    )}
    {s.kind === 'light' && (
      <g transform="translate(150 165)">
        <!-- LED bar -->
        <rect x="-90" y="-12" width="180" height="24" rx="12" fill="rgba(0,0,0,0.35)"/>
        <rect x="-86" y="-8" width="172" height="16" rx="8" fill="#0C2146"/>
        <!-- LEDs -->
        {[...Array(7)].map((_, i) => (
          <circle cx={-72 + i * 24} cy="0" r="3" fill="#FFFCC4"/>
        ))}
        <!-- Light glow -->
        <ellipse cx="0" cy="50" rx="120" ry="36" fill="rgba(255,252,196,0.18)"/>
        <text x="0" y="-30" text-anchor="middle" font-family="Oswald, sans-serif" font-weight="700" font-size="12" fill="white" letter-spacing="2">5W · 6500K</text>
      </g>
    )}
  </svg>

  <!-- Top-left CCS chip -->
  <div class="absolute top-3 left-3 flex items-center gap-2">
    <div class="w-7 h-7 rounded-full bg-white grid place-items-center shadow-soft">
      <span class="font-display font-bold text-[9px] tracking-tight text-brand-red">C<span class="text-brand-blue">S</span>C</span>
    </div>
    <span class="font-mono text-[10px] uppercase tracking-tight" style={`color: ${subtle};`}>
      {category.slice(0, 20)}
    </span>
  </div>

  <!-- Bottom-right brand pill -->
  <div class="absolute bottom-3 left-3" style={`color: ${ink};`}>
    <p class="font-mono text-[10px] uppercase tracking-[0.18em]" style={`color: ${subtle};`}>Brand</p>
    <p class="font-display font-bold text-[14px] tracking-tight">{brand}</p>
  </div>
</div>
