---
import Icon from './Icon.astro';
import type { Product } from '@/data/products';
interface Props { product: Product; index?: number; }
const { product: p, index = 0 } = Astro.props;
---
<article class="card-lift group bg-snow border border-line rounded-3xl overflow-hidden reveal" data-delay={`${(index % 4) + 1}`}>
  <div class="relative aspect-square bg-bone overflow-hidden">
    <img
      src={p.image}
      alt={p.title}
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-[900ms] ease-[cubic-bezier(.2,.7,.2,1)] group-hover:scale-[1.07]"
    />
    <div class="absolute top-3 left-3 flex flex-wrap gap-1.5">
      {p.tags.map((t) => (
        <span class="font-display uppercase text-[10px] tracking-wider bg-white/95 text-ink px-2 py-0.5 rounded-full backdrop-blur">{t}</span>
      ))}
    </div>
    <div class="absolute bottom-3 right-3 font-display font-semibold bg-brand-red text-white text-[14px] px-3 py-1.5 rounded-pill shadow-glow">{p.price}</div>
  </div>
  <div class="p-5">
    <p class="font-mono text-[11px] uppercase tracking-wider text-muted">{p.brand} · {p.category}</p>
    <h3 class="mt-2 font-display font-semibold text-[17px] text-ink leading-tight">{p.title}</h3>
    <p class="mt-1 text-[12.5px] text-muted-soft">{p.size}</p>
    <p class="mt-3 text-[13.5px] text-muted leading-relaxed line-clamp-3">{p.blurb}</p>
    <div class="mt-4 flex items-center justify-between gap-3">
      <a href={`/shop`} class="inline-flex items-center gap-1.5 text-[12.5px] font-display uppercase tracking-wider text-brand-blue link-underline">
        View Product <Icon name="arrow-right" size={12} />
      </a>
      <button type="button" class="text-[11px] font-display uppercase tracking-wider px-3 py-1.5 rounded-pill bg-ink/5 text-ink hover:bg-brand-red hover:text-white transition-colors">
        Enquire
      </button>
    </div>
  </div>
</article>
