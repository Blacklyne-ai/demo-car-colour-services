---
import { SITE } from '@/data/site';
import { CATEGORIES } from '@/data/categories';
import Icon from './Icon.astro';
import OpeningHoursLive from './OpeningHoursLive.astro';

const year = new Date().getFullYear();
---
<footer class="relative mesh-blue-dark text-white pt-24 pb-10 overflow-hidden">
  <!-- Atmospheric noise -->
  <div class="noise absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <div class="container-x relative">
    <!-- Top closing line -->
    <div class="grid lg:grid-cols-[1.2fr_1fr] gap-12 lg:gap-20 mb-20">
      <div>
        <p class="eyebrow text-brand-red-soft" style="--tw-text-opacity:1;">Get In Touch</p>
        <h2 class="h-section text-white mt-3 text-balance">
          Talk to the team that has been<br/>mixing colour in Romford <span class="text-brand-red-soft">since 1990</span>.
        </h2>
        <p class="mt-5 text-white/70 max-w-xl text-pretty">
          Whether you are running a busy bodyshop, restoring a one-off project or hunting a touch-up aerosol for a single panel — call, email, or walk in. No call queues, no chatbots, no menu options.
        </p>
        <div class="flex flex-wrap gap-3 mt-7">
          <a href={`tel:${SITE.phoneTel}`} class="btn-primary"><Icon name="phone" size={16} /><span>{SITE.phone}</span></a>
          <a href={`mailto:${SITE.email}`} class="btn-secondary !text-white !bg-white/8 !border-white/15 hover:!bg-white/12"><Icon name="mail" size={16} /><span>{SITE.email}</span></a>
        </div>
      </div>

      <!-- Map block -->
      <div class="rounded-3xl overflow-hidden border border-white/10 bg-white/5 backdrop-blur-sm">
        <iframe
          title="Map of Car Colour Services — 92-94 Mawney Road, Romford"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.openstreetmap.org/export/embed.html?bbox=0.165%2C51.572%2C0.190%2C51.583&layer=mapnik&marker=51.5774%2C0.1772"
          class="w-full h-64 lg:h-full block grayscale opacity-90"
        ></iframe>
      </div>
    </div>

    <!-- Multi-tier link grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-10 lg:gap-12 pb-14 border-b border-white/10">
      <div class="col-span-2 lg:col-span-2">
        <a href="/" class="flex items-center gap-3" aria-label="Car Colour Services home">
          <img src="/logo-mark.svg" alt="" width="48" height="48" class="w-12 h-12 bg-white rounded-full p-0.5" />
          <div>
            <p class="font-display font-bold uppercase tracking-wider text-white">Car Colour Services</p>
            <p class="text-[11px] uppercase tracking-[0.22em] text-white/55 font-display">The Complete Colour Service</p>
          </div>
        </a>
        <p class="text-white/65 text-sm mt-5 max-w-md leading-relaxed">
          Independent automotive paint specialists serving trade bodyshops, classic restorers and private motorists across the South East. Same family. Same building. Since 1990.
        </p>
        <div class="mt-6 flex items-center gap-3">
          <a href={SITE.social.facebook} target="_blank" rel="noopener" class="w-10 h-10 grid place-items-center rounded-full bg-white/8 hover:bg-brand-red transition-colors" aria-label="Car Colour Services on Facebook">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.13 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.52 1.49-3.91 3.78-3.91 1.1 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.77-1.63 1.56v1.87h2.78l-.45 2.9h-2.33V22c4.78-.81 8.44-4.94 8.44-9.94z"/></svg>
          </a>
          <a href={SITE.social.linkedin} target="_blank" rel="noopener" class="w-10 h-10 grid place-items-center rounded-full bg-white/8 hover:bg-brand-blue transition-colors" aria-label="Car Colour Services on LinkedIn">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.8 0 0 .77 0 1.72v20.55C0 23.23.8 24 1.77 24h20.45c.97 0 1.78-.77 1.78-1.73V1.72C24 .77 23.19 0 22.22 0z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <p class="font-display uppercase tracking-wider text-[11px] text-white/45 mb-4">Shop</p>
        <ul class="space-y-2.5 text-sm">
          {CATEGORIES.slice(0, 6).map((c) => (
            <li><a href={`/shop/${c.slug}`} class="text-white/75 hover:text-white transition link-underline">{c.title}</a></li>
          ))}
          <li><a href="/shop" class="text-brand-red-soft hover:text-white transition font-medium">All categories →</a></li>
        </ul>
      </div>

      <div>
        <p class="font-display uppercase tracking-wider text-[11px] text-white/45 mb-4">Company</p>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/who-we-are" class="text-white/75 hover:text-white">Who We Are</a></li>
          <li><a href="/classic-cars" class="text-white/75 hover:text-white">Classic Cars</a></li>
          <li><a href="/trade-account" class="text-white/75 hover:text-white">Trade Account</a></li>
          <li><a href="/body-shop-referrals" class="text-white/75 hover:text-white">Body-Shop Network</a></li>
          <li><a href="/colour-matching" class="text-white/75 hover:text-white">Colour Matching</a></li>
          <li><a href="/contact" class="text-white/75 hover:text-white">Contact</a></li>
        </ul>
      </div>

      <div>
        <p class="font-display uppercase tracking-wider text-[11px] text-white/45 mb-4">Visit</p>
        <address class="not-italic text-sm text-white/75 leading-relaxed">
          {SITE.address.street}<br/>
          {SITE.address.city}, {SITE.address.county}<br/>
          {SITE.address.postcode}<br/>
          {SITE.address.country}
        </address>
        <div class="mt-4">
          <OpeningHoursLive variant="inline" class="!text-white/85" />
        </div>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href={`tel:${SITE.phoneTel}`} class="inline-flex items-center gap-2 text-white/85 hover:text-white"><Icon name="phone" size={14} />{SITE.phone}</a></li>
          <li><a href={`mailto:${SITE.email}`} class="inline-flex items-center gap-2 text-white/85 hover:text-white"><Icon name="mail" size={14} />{SITE.email}</a></li>
        </ul>
      </div>
    </div>

    <!-- B2B-trust micro-footer -->
    <div class="pt-8 flex flex-col lg:flex-row items-start lg:items-center justify-between gap-5 text-[12px] text-white/55">
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <span>© {year} {SITE.legalName}.</span>
        <span>Companies House <a href={`https://find-and-update.company-information.service.gov.uk/company/${SITE.companiesHouseNumber}`} target="_blank" rel="noopener" class="hover:text-white underline-offset-2 hover:underline">#{SITE.companiesHouseNumber}</a></span>
        <span class="hidden lg:inline">·</span>
        <span>Registered in England</span>
      </div>
      <ul class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <li><a href="/privacy" class="hover:text-white">Privacy</a></li>
        <li><a href="/cookies" class="hover:text-white">Cookies</a></li>
        <li><a href="/terms" class="hover:text-white">Terms</a></li>
        <li><a href="https://blacklyne.ai" target="_blank" rel="noopener" class="hover:text-white inline-flex items-center gap-1">Built by Blacklyne <Icon name="arrow-up-right" size={11} /></a></li>
      </ul>
    </div>
  </div>
</footer>
