---
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/Icon.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import StatsCounter from '@/components/StatsCounter.astro';
import CategoryCard from '@/components/CategoryCard.astro';
import CategoryArtwork from '@/components/CategoryArtwork.astro';
import ProductCard from '@/components/ProductCard.astro';
import BrandMarquee from '@/components/BrandMarquee.astro';
import ReviewsSection from '@/components/ReviewsSection.astro';
import ColourMatchForm from '@/components/ColourMatchForm.astro';
import ReferralMap from '@/components/ReferralMap.astro';
import CtaBand from '@/components/CtaBand.astro';
import FloatingCTA from '@/components/FloatingCTA.astro';
import { CATEGORIES } from '@/data/categories';
import { FEATURED_PRODUCTS } from '@/data/products';
import { SITE } from '@/data/site';
---
<Layout>
  <!-- ──────────────────────────────────────── CINEMATIC HERO ──────────────────────────────────────── -->
  <section class="relative min-h-[88vh] lg:min-h-[92vh] -mt-24 pt-24 flex items-end overflow-hidden">
    <!-- Layered hero background -->
    <div class="absolute inset-0" aria-hidden="true">
      <!-- Real photography: the actual storefront -->
      <img
        src="/shopfront-hero.jpg"
        alt=""
        class="absolute inset-0 w-full h-full object-cover"
        data-parallax="0.2"
        fetchpriority="high"
      />
      <!-- Editorial overlay: dark gradient bottom for headline legibility -->
      <div class="absolute inset-0 bg-gradient-to-t from-brand-blue-deep/95 via-brand-blue-deep/60 to-brand-blue-deep/30"></div>
      <!-- Brand colour accent -->
      <div class="absolute inset-0 opacity-50" style="background: radial-gradient(circle at 18% 110%, rgb(206 42 45 / 0.25) 0%, transparent 45%);"></div>
      <!-- Subtle noise -->
      <div class="noise absolute inset-0"></div>
    </div>

    <div class="container-x relative z-10 pb-16 lg:pb-24">
      <div class="grid lg:grid-cols-[1.4fr_1fr] gap-10 items-end">
        <div class="text-white">
          <p class="eyebrow text-brand-red-soft reveal" style="--tw-text-opacity:1;">Romford, Essex · Independent since 1990</p>
          <h1 class="h-display mt-5 text-white text-balance reveal" data-delay="1">
            The right colour.<br/>
            <span class="text-brand-red-soft">Mixed by hand.</span><br/>
            <span class="text-white/70">In your tin by lunchtime.</span>
          </h1>
          <p class="mt-7 text-white/80 max-w-xl text-lg leading-relaxed text-pretty reveal" data-delay="2">
            Independent automotive paint specialists supplying trade bodyshops, classic restorers and private motorists across the South East. Same family. Same building. Since 1990.
          </p>
          <div class="flex flex-wrap gap-3 mt-9 reveal" data-delay="3">
            <a href="/colour-matching" class="btn-primary text-base !py-4 !px-7">
              <Icon name="palette" size={17} />
              <span>Match My Colour</span>
              <Icon name="arrow-right" class="arrow" size={16} />
            </a>
            <a href="/shop" class="btn-secondary !text-white !bg-white/10 !border-white/20 hover:!bg-white/15 text-base !py-4 !px-7">
              <span>Browse the Catalogue</span>
              <Icon name="arrow-up-right" size={16} />
            </a>
          </div>
        </div>

        <!-- Hero call-out card (glass) -->
        <div class="reveal" data-delay="4">
          <div class="glass-card rounded-3xl p-6 lg:p-7 bg-white/10 border-white/15 text-white backdrop-blur-xl">
            <p class="eyebrow text-brand-red-soft" style="--tw-text-opacity:1;">Today at the Shop</p>
            <p class="mt-3 font-display font-semibold text-xl leading-snug">Aerosols made-to-order. Trade counter open. Walk-ins welcome.</p>
            <div class="mt-5 grid grid-cols-2 gap-3 text-center">
              <a href={`tel:${SITE.phoneTel}`} class="flex flex-col items-start text-left p-3.5 rounded-2xl bg-white/8 hover:bg-white/12 transition-colors">
                <Icon name="phone" size={16} class="text-brand-red-soft" />
                <p class="text-[11px] uppercase tracking-wider font-display text-white/60 mt-2">Call</p>
                <p class="font-display font-semibold text-[14px]">{SITE.phone}</p>
              </a>
              <a href={`mailto:${SITE.email}`} class="flex flex-col items-start text-left p-3.5 rounded-2xl bg-white/8 hover:bg-white/12 transition-colors">
                <Icon name="mail" size={16} class="text-brand-red-soft" />
                <p class="text-[11px] uppercase tracking-wider font-display text-white/60 mt-2">Email</p>
                <p class="font-medium text-[12.5px] truncate">{SITE.email}</p>
              </a>
            </div>
            <p class="mt-5 text-[12.5px] text-white/60 flex items-start gap-2">
              <Icon name="map-pin" size={13} class="mt-0.5 flex-shrink-0" />
              <span>{SITE.address.street}, {SITE.address.city}, {SITE.address.postcode}</span>
            </p>
          </div>
        </div>
      </div>

      <!-- Trust strip — slide in last -->
      <div class="mt-14 lg:mt-20 grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-4 border-t border-white/15 pt-7 reveal" data-delay="5">
        {[
          { v: '35+', l: 'Years Trading' },
          { v: '600+', l: 'Product Lines' },
          { v: '40+', l: 'Car Marques' },
          { v: '4.9★', l: 'Google Rating' },
        ].map((t) => (
          <div class="text-white">
            <p class="font-display font-bold text-3xl lg:text-4xl text-brand-red-soft leading-none">{t.v}</p>
            <p class="text-[11.5px] uppercase tracking-wider font-display text-white/65 mt-1.5">{t.l}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────── WELCOME / EDITORIAL ──────────────────────────────────────── -->
  <section class="relative py-24 lg:py-32 bg-snow">
    <div class="container-x grid lg:grid-cols-[1fr_1.6fr] gap-12 lg:gap-20">
      <div>
        <p class="eyebrow reveal">Welcome to CCS</p>
        <h2 class="h-section mt-4 text-balance reveal" data-delay="1">
          The number one place to buy<br/>car paint in the <span class="text-brand-red">South East</span>.
        </h2>
        <div class="gradient-divider mt-8 reveal" data-delay="2"></div>
        <div class="mt-8 flex items-center gap-4 reveal" data-delay="3">
          <span class="flex items-center -space-x-2">
            <span class="w-9 h-9 rounded-full bg-brand-red/15 grid place-items-center font-display font-bold text-[12px] text-brand-red border-2 border-snow">JM</span>
            <span class="w-9 h-9 rounded-full bg-brand-blue/15 grid place-items-center font-display font-bold text-[12px] text-brand-blue border-2 border-snow">SP</span>
            <span class="w-9 h-9 rounded-full bg-brand-red/15 grid place-items-center font-display font-bold text-[12px] text-brand-red border-2 border-snow">DH</span>
          </span>
          <p class="text-[13px] text-muted">Trusted by hundreds of bodyshops and motorists across Essex &amp; East London.</p>
        </div>
      </div>

      <div class="lg:pl-8 lg:border-l lg:border-line">
        <p class="dropcap text-[17px] lg:text-[18px] text-ink/85 leading-[1.75] text-pretty reveal" data-delay="1">
          The condition of your paintwork is one of the first things that someone will notice about your car. So any scratches, chips or damage will really attract a lot of unwanted attention. If your paintwork is a little past its best, then you have come to the right place. We are Car Colour Services, the number one place to buy car paint in the South East.
        </p>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────── STATS COUNTER ──────────────────────────────────────── -->
  <section class="bg-snow pb-24 lg:pb-32">
    <div class="container-x">
      <StatsCounter variant="light" />
    </div>
  </section>

  <!-- ──────────────────────────────────────── INDEPENDENCE USP (the central differentiation) ──────────────────────────────────────── -->
  <section class="relative mesh-blue-dark py-24 lg:py-36 overflow-hidden">
    <div class="noise absolute inset-0 pointer-events-none" aria-hidden="true"></div>
    <!-- Floating brand accent -->
    <div class="absolute top-10 right-10 w-72 h-72 rounded-full opacity-40 pointer-events-none" style="background: radial-gradient(circle, rgb(206 42 45 / 0.4) 0%, transparent 70%);"></div>

    <div class="container-x relative grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="text-white">
        <p class="eyebrow text-brand-red-soft reveal" style="--tw-text-opacity:1;">Why Independent Matters</p>
        <h2 class="h-section mt-4 text-balance reveal" data-delay="1">
          No targets.<br/>No rebates.<br/><span class="text-brand-red-soft">No agenda.</span>
        </h2>
        <p class="mt-6 text-white/80 text-lg leading-relaxed text-pretty reveal" data-delay="2">
          Car Colour Services is an independently owned company, and that independence is central to how we work. We are not tied to manufacturer incentives or rebate-driven targets — so when we recommend a paint system, it is because it is the right one for <em class="text-white">your</em> job.
        </p>
        <p class="mt-4 text-white/70 leading-relaxed text-pretty reveal" data-delay="3">
          We have built our reputation on knowledge, service, and long-term relationships — helping customers achieve consistently high-quality results, whether they are running a busy bodyshop or working on a one-off vehicle project.
        </p>
        <div class="flex flex-wrap gap-3 mt-8 reveal" data-delay="4">
          <a href="/who-we-are" class="btn-primary"><Icon name="users" size={15} /><span>Our Story</span></a>
          <a href="/trade-account" class="btn-secondary !text-white !bg-white/10 !border-white/15 hover:!bg-white/15"><Icon name="shield" size={15} /><span>Open a Trade Account</span></a>
        </div>
      </div>

      <!-- Editorial pull-quote / proof block -->
      <div class="relative reveal" data-delay="3">
        <div class="absolute -top-6 -left-2 text-brand-red-soft opacity-40">
          <Icon name="quote" size={88} />
        </div>
        <blockquote class="relative pl-8 lg:pl-14">
          <p class="font-display font-medium text-2xl lg:text-3xl text-white leading-snug text-pretty">
            "We do not push the brand the rep tells us to push this week. We push the one that will get your colour right the first time."
          </p>
          <footer class="mt-6 pl-4 border-l-2 border-brand-red-soft">
            <p class="font-display uppercase tracking-wider text-[12px] text-brand-red-soft">The CCS Team</p>
            <p class="text-white/60 text-[14px] mt-1">Mawney Road, Romford · Since 1990</p>
          </footer>
        </blockquote>

        <!-- Trust ribbons -->
        <div class="mt-12 grid grid-cols-3 gap-3 text-center">
          {[
            { v: 'Independent', s: 'Family-run' },
            { v: 'No Rebates', s: 'Honest advice' },
            { v: '35+ Years', s: 'Same building' },
          ].map((b) => (
            <div class="glass-card rounded-2xl p-4 bg-white/8 border-white/12">
              <p class="font-display font-bold text-white text-[14.5px]">{b.v}</p>
              <p class="text-[11px] text-white/60 mt-1 uppercase tracking-wider font-display">{b.s}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────── 7 CATEGORIES ──────────────────────────────────────── -->
  <section class="relative py-24 lg:py-32 bg-snow">
    <div class="container-x">
      <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-14">
        <SectionHeading
          eyebrow="Find the Perfect Car Paint"
          title="Seven categories. <span class='text-brand-red'>Six hundred</span> products. One mixing room."
          intro="For over 35 years, we have been bringing the best paint for cars to motorists in the South East. Operating from our store in the heart of Romford, Greater London, we have built a catalogue that covers every job — from a touch-up aerosol to full bodyshop volume orders."
        />
        <a href="/shop" class="btn-secondary self-start lg:self-end shrink-0 reveal" data-delay="3"><span>Shop All Categories</span><Icon name="arrow-right" class="arrow" size={15} /></a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-7">
        {CATEGORIES.slice(0, 6).map((c, i) => <CategoryCard category={c} index={i} />)}
      </div>
      <!-- 7th category as wide editorial card -->
      <div class="mt-5 lg:mt-7">
        <a href={`/shop/${CATEGORIES[6].slug}`} class="group block relative overflow-hidden rounded-3xl border border-line bg-snow card-lift reveal" data-delay="1">
          <div class="grid md:grid-cols-[1.4fr_1fr] gap-0">
            <div class="p-8 lg:p-12 order-2 md:order-1">
              <div class="flex items-center gap-3">
                <span class="w-11 h-11 rounded-2xl bg-brand-red/10 text-brand-red grid place-items-center"><Icon name="wrench" size={20} /></span>
                <span class="font-mono text-[11px] tracking-tight text-muted">{CATEGORIES[6].count}</span>
              </div>
              <h3 class="h-card mt-5 group-hover:text-brand-red transition-colors">{CATEGORIES[6].title}</h3>
              <p class="mt-3 text-muted text-[15px] leading-relaxed text-pretty max-w-md">{CATEGORIES[6].blurb}</p>
              <span class="mt-6 inline-flex items-center gap-2 font-display uppercase tracking-wider text-[12px] text-brand-red">Browse Range <Icon name="arrow-right" class="arrow" size={14} /></span>
            </div>
            <div class="relative aspect-[4/3] md:aspect-auto overflow-hidden order-1 md:order-2 min-h-[260px]">
              <CategoryArtwork slug={CATEGORIES[6].slug} title={CATEGORIES[6].title} count={CATEGORIES[6].count} wide />
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────── COLOUR MATCH TOOL ──────────────────────────────────────── -->
  <ColourMatchForm />

  <!-- ──────────────────────────────────────── FEATURED PRODUCTS ──────────────────────────────────────── -->
  <section class="relative py-24 lg:py-32 bg-snow">
    <div class="container-x">
      <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-12">
        <SectionHeading
          eyebrow="Buy Car Paint Online"
          eyebrowVariant="blue"
          title="Trade picks. <span class='text-brand-blue'>Workshop tested.</span>"
          intro="The lines bodyshops keep coming back for. Hand-selected by the team for finish, speed and reliability."
        />
        <a href="/shop" class="btn-secondary self-start lg:self-end shrink-0 reveal" data-delay="3"><span>All Products</span><Icon name="arrow-right" class="arrow" size={15} /></a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6">
        {FEATURED_PRODUCTS.map((p, i) => <ProductCard product={p} index={i} />)}
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────── CLASSIC CARS — CINEMATIC HERITAGE ──────────────────────────────────────── -->
  <section class="relative py-28 lg:py-40 overflow-hidden bg-brand-blue-deep text-white">
    <!-- Brand-coloured cinematic mesh backdrop -->
    <div class="absolute inset-0" aria-hidden="true">
      <div class="absolute inset-0" style="background:
        radial-gradient(at 20% 30%, rgb(45 79 44 / 0.55) 0%, transparent 55%),
        radial-gradient(at 80% 50%, rgb(206 42 45 / 0.32) 0%, transparent 60%),
        radial-gradient(at 50% 100%, rgb(28 58 111 / 0.5) 0%, transparent 60%),
        linear-gradient(180deg, #0C2146 0%, #10182A 100%);"></div>
      <!-- Decorative concentric wheel motif -->
      <svg viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice" class="absolute inset-0 w-full h-full opacity-25" aria-hidden="true">
        <g transform="translate(620 320)" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.5">
          <circle r="160"/><circle r="120"/><circle r="80"/><circle r="40"/>
          <line x1="-160" y1="0" x2="160" y2="0"/>
          <line x1="0" y1="-160" x2="0" y2="160"/>
          <line x1="-113" y1="-113" x2="113" y2="113"/>
          <line x1="-113" y1="113"  x2="113" y2="-113"/>
        </g>
      </svg>
      <div class="noise absolute inset-0"></div>
    </div>

    <div class="container-x relative grid lg:grid-cols-[1.2fr_1fr] gap-12 items-center">
      <div>
        <p class="eyebrow text-brand-red-soft reveal" style="--tw-text-opacity:1;">A Quarter of a Century in Classic</p>
        <h2 class="font-display font-bold leading-[0.96] text-balance reveal mt-4" data-delay="1" style="font-size: clamp(2.5rem, 5.4vw, 4.75rem);">
          For <span class="text-brand-red-soft">25 years</span><br/>
          we have mixed for<br/>
          the cars worth saving.
        </h2>
        <p class="mt-7 text-white/80 text-lg leading-relaxed max-w-xl text-pretty reveal" data-delay="2">
          Car Colour Services has served the Classic Car market for over 25 years, from proud owners starting a new project to world-class restoration companies who we serve daily. Cellulose, synthetic, period-correct — we still mix it.
        </p>
        <div class="flex flex-wrap gap-3 mt-8 reveal" data-delay="3">
          <a href="/classic-cars" class="btn-primary"><Icon name="history" size={15} /><span>Classic Services</span><Icon name="arrow-right" class="arrow" size={15} /></a>
          <a href="/colour-matching" class="btn-secondary !text-white !bg-white/10 !border-white/15 hover:!bg-white/15"><span>Match a Vintage Colour</span></a>
        </div>
      </div>

      <!-- Editorial classic-car spec card -->
      <div class="relative reveal" data-delay="3">
        <div class="glass-card rounded-3xl p-7 bg-white/8 border-white/12 backdrop-blur-xl">
          <p class="eyebrow text-brand-red-soft" style="--tw-text-opacity:1;">Mixed This Week</p>
          <ul class="mt-5 space-y-4">
            {[
              { car: 'MGB GT', year: '1972', code: 'BRG / British Racing Green', system: 'Cellulose' },
              { car: 'Jaguar E-Type', year: '1968', code: 'Opalescent Silver Blue', system: '2K Acrylic' },
              { car: 'Mini Cooper S', year: '1965', code: 'Almond Green / Old English', system: 'Synthetic Enamel' },
              { car: 'Triumph TR6', year: '1974', code: 'Pimento Red', system: 'Cellulose' },
            ].map((c) => (
              <li class="flex items-start gap-4 pb-4 border-b border-white/10 last:border-0 last:pb-0">
                <span class="flex-shrink-0 w-10 h-10 rounded-xl bg-brand-red/20 text-brand-red-soft grid place-items-center"><Icon name="car-front" size={18} /></span>
                <div class="flex-1 min-w-0">
                  <p class="font-display font-semibold text-[14.5px]">{c.car} <span class="text-white/55 font-normal">· {c.year}</span></p>
                  <p class="text-[12.5px] text-white/70 mt-0.5">{c.code}</p>
                </div>
                <span class="font-mono text-[11px] text-white/55 uppercase tracking-tight">{c.system}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────── 40+ BRAND MARQUEE ──────────────────────────────────────── -->
  <BrandMarquee />

  <!-- ──────────────────────────────────────── BODY SHOP NETWORK ──────────────────────────────────────── -->
  <section class="relative py-24 lg:py-32 bg-bone">
    <div class="container-x grid lg:grid-cols-[1fr_1.4fr] gap-12 lg:gap-16 items-center">
      <div>
        <p class="eyebrow eyebrow-blue reveal">Find Local Car Body Repair Experts</p>
        <h2 class="h-section mt-4 text-balance reveal" data-delay="1">
          Need it sprayed?<br/>We know <span class="text-brand-blue">who to call</span>.
        </h2>
        <p class="mt-5 text-muted text-[15.5px] leading-relaxed text-pretty reveal" data-delay="2">
          As a paint specialist, our home is in the mixing room. But over 35 years we have built deep relationships with skilled bodyshops across Essex, East London and the wider South East. Tell us where you are and what the job is — we will refer you to a shop we genuinely trust.
        </p>
        <ul class="mt-7 grid grid-cols-2 gap-2 reveal" data-delay="3">
          {['Romford', 'Brentwood', 'Chelmsford', 'Southend', 'Ilford', 'Dagenham', 'Hornchurch', 'Basildon'].map((a) => (
            <li class="flex items-center gap-2 text-[14px] text-ink/80">
              <Icon name="map-pin" size={13} class="text-brand-red" /> {a}
            </li>
          ))}
        </ul>
        <div class="mt-8 reveal" data-delay="4">
          <a href="/body-shop-referrals" class="btn-primary"><Icon name="users" size={15} /><span>See the Referral Network</span><Icon name="arrow-right" class="arrow" size={15} /></a>
        </div>
      </div>
      <div class="reveal" data-delay="2">
        <ReferralMap />
      </div>
    </div>
  </section>

  <!-- ──────────────────────────────────────── REVIEWS ──────────────────────────────────────── -->
  <ReviewsSection />

  <!-- ──────────────────────────────────────── CTA BAND ──────────────────────────────────────── -->
  <CtaBand
    title="Get In Touch."
    body="Walk into the shop on Mawney Road, ring us at 01708 746468 or send a paint code over by email. The mixing room is on. The kettle is on. The catalogue is open."
  />

  <FloatingCTA />
</Layout>
