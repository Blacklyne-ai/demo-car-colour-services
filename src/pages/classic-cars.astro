---
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/Icon.astro';
import CtaBand from '@/components/CtaBand.astro';
import FloatingCTA from '@/components/FloatingCTA.astro';
import { SITE } from '@/data/site';

const CLASSIC_LINES = [
  { name: 'Cellulose Paints',     blurb: 'Authentic single-pack cellulose nitrate finishes. The period-correct choice for restoration.' },
  { name: 'Synthetic Enamels',    blurb: 'Long-life single-pack enamels with deep gloss retention. Ideal for commercial and classic vehicles.' },
  { name: '2K Acrylic Systems',   blurb: 'Modern two-pack basecoats matched to vintage colour references for daily-driven classics.' },
  { name: 'Custom Mix Service',   blurb: 'Bring us a panel, a chip or the manufacturer code. We will mix it on the bench — usually same-day.' },
  { name: 'Period-Correct Primer', blurb: 'Etch, zinc and high-build primers compatible with classic substrates including aluminium and lead-loaded steel.' },
  { name: 'Touch-Up Aerosols',     blurb: 'Aerosols made-to-order in vintage colours for spot repairs without dropping the panel.' },
];

const PROCESS = [
  { n: '01', t: 'Tell Us the Car',  d: 'Make, model, year and any paint code or panel reference you have. A photograph helps.' },
  { n: '02', t: 'We Source the Colour', d: 'Our mix room cross-references manufacturer archives and our own 35-year colour library.' },
  { n: '03', t: 'Mix and Match', d: 'We mix to spec on the bench — single-pack cellulose, synthetic enamel, modern 2K acrylic, your choice.' },
  { n: '04', t: 'You Collect or We Post', d: 'Walk into the shop or order online. Trade volumes available, aerosols posted next-day.' },
];
---
<Layout title={`Classic Cars — ${SITE.name}`} description="25+ years mixing paint for classic-car restoration projects. Cellulose, synthetic enamel and 2K acrylic systems — period-correct or modern equivalents.">
  <!-- Cinematic hero -->
  <section class="relative pt-20 pb-32 lg:pt-28 lg:pb-44 overflow-hidden bg-brand-blue-deep text-white">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1494976388531-d1058494cdd8?w=1800&q=82&auto=format&fit=crop"
        alt=""
        class="w-full h-full object-cover opacity-55"
        data-parallax="0.15"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-blue-deep via-brand-blue-deep/80 to-brand-blue-deep/40"></div>
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 80% 30%, rgb(206 42 45 / 0.22) 0%, transparent 60%);"></div>
      <div class="noise absolute inset-0"></div>
    </div>
    <div class="container-x relative">
      <p class="eyebrow text-brand-red-soft reveal" style="--tw-text-opacity:1;">Classic Car Restoration · 25+ Years</p>
      <h1 class="font-display font-bold leading-[0.96] text-balance reveal mt-5" data-delay="1" style="font-size: clamp(2.75rem, 6.8vw, 5.75rem);">
        For the cars<br/>
        <span class="text-brand-red-soft">worth saving</span>.
      </h1>
      <p class="mt-6 max-w-2xl text-lg lg:text-xl text-white/80 leading-relaxed text-pretty reveal" data-delay="2">
        Car Colour Services has served the Classic Car market for over 25 years, from proud owners starting a new project to world-class restoration companies who we serve daily.
      </p>
      <div class="flex flex-wrap gap-3 mt-9 reveal" data-delay="3">
        <a href="/colour-matching" class="btn-primary"><Icon name="palette" size={15} /><span>Match a Vintage Colour</span></a>
        <a href={`tel:${SITE.phoneTel}`} class="btn-secondary !text-white !bg-white/10 !border-white/15 hover:!bg-white/15"><Icon name="phone" size={15} /><span>Talk to a Specialist</span></a>
      </div>
    </div>
  </section>

  <!-- Editorial pull-quote moment -->
  <section class="relative py-24 lg:py-32 bg-snow">
    <div class="container-x max-w-5xl">
      <blockquote class="relative">
        <Icon name="quote" size={64} class="text-brand-red opacity-25" />
        <p class="font-display font-medium text-3xl lg:text-5xl text-ink leading-[1.15] mt-6 text-balance">
          A 1972 BRG <em class="not-italic text-brand-red">should look</em> like 1972 BRG.<br class="hidden lg:block" />
          Not the closest <em class="not-italic text-brand-blue">modern equivalent</em>.
        </p>
        <footer class="mt-8 flex items-center gap-4 pl-1">
          <span class="w-12 h-12 rounded-full bg-brand-red/10 text-brand-red grid place-items-center font-display font-bold">CCS</span>
          <div>
            <p class="font-display font-semibold text-ink">The Mix Room Philosophy</p>
            <p class="text-muted text-[14px]">Since 1990 · Romford, Essex</p>
          </div>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Classic systems editorial grid -->
  <section class="py-24 lg:py-32 bg-bone">
    <div class="container-x">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow reveal">Classic Systems Stocked</p>
        <h2 class="h-section mt-4 text-balance reveal" data-delay="1">Cellulose. Synthetic. 2K acrylic.<br/><span class="text-brand-red">All on the shelf.</span></h2>
        <p class="mt-5 text-muted text-[15.5px] reveal" data-delay="2">Cellulose-nitrate enamels disappeared from most paint factors twenty years ago. We never stopped stocking them.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {CLASSIC_LINES.map((l, i) => (
          <div class="card-lift bg-snow rounded-3xl border border-line p-7 reveal" data-delay={`${(i % 4) + 1}`}>
            <div class="flex items-center gap-3 mb-4">
              <span class={`w-10 h-10 rounded-xl ${i % 2 === 0 ? 'bg-brand-red/10 text-brand-red' : 'bg-brand-blue/10 text-brand-blue'} grid place-items-center`}>
                <Icon name={i % 2 === 0 ? 'beaker' : 'brush'} size={18} />
              </span>
              <p class="font-mono text-[11px] uppercase tracking-tight text-muted">0{i + 1} / 06</p>
            </div>
            <h3 class="h-card text-ink">{l.name}</h3>
            <p class="mt-3 text-[14.5px] text-muted leading-relaxed">{l.blurb}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process timeline -->
  <section class="py-24 lg:py-32 bg-snow">
    <div class="container-x">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow eyebrow-blue reveal">How It Works</p>
        <h2 class="h-section mt-4 text-balance reveal" data-delay="1">From paint code<br/>to <span class="text-brand-blue">collected tin</span>.</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-px bg-line rounded-3xl overflow-hidden">
        {PROCESS.map((p, i) => (
          <div class="bg-snow p-7 lg:p-9 reveal" data-delay={`${(i % 4) + 1}`}>
            <p class="font-mono text-[12px] text-brand-red tracking-tight">{p.n}</p>
            <h3 class="font-display font-semibold text-[18px] mt-4 text-ink">{p.t}</h3>
            <p class="mt-2.5 text-[14px] text-muted leading-relaxed">{p.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    title="Working on something special?"
    body="Bring us a panel, a chip, a manufacturer code or a photograph. The mixing room loves a challenge."
  />
  <FloatingCTA />
</Layout>
